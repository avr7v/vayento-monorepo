PORT=4000
NODE_ENV=development

# Local Docker compose exposes Postgres on localhost:5433
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/vayento?schema=public"

JWT_ACCESS_SECRET="change-me-access-secret"
JWT_SECRET="change-me-access-secret"
JWT_REFRESH_SECRET="change-me-refresh-secret"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"
REQUIRE_EMAIL_VERIFICATION=false
AUTO_VERIFY_REGISTERED_USERS=true
JWT_EMAIL_VERIFICATION_REQUIRED=false

CORS_ALLOWED_ORIGINS="http://localhost:3000,http://127.0.0.1:3000"
FRONTEND_URL="http://localhost:3000"

# Local email catcher: docker compose up -d mailpit, then open http://localhost:8025
MAIL_FROM="Vayento <no-reply@vayento.local>"
SMTP_FROM="Vayento <no-reply@vayento.local>"
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=local
SMTP_PASS=local
SMTP_SECURE=false
ADMIN_ALERT_EMAIL="admin@vayento.local"

# Stripe test mode. Leave empty to use mock payment mode.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Local MinIO from docker-compose
STORAGE_BUCKET="vayento-media"
STORAGE_REGION="eu-central-1"
STORAGE_ENDPOINT="http://localhost:9000"
STORAGE_ACCESS_KEY_ID="minioadmin"
STORAGE_SECRET_ACCESS_KEY="minioadmin"
STORAGE_PUBLIC_BASE_URL="http://localhost:9000/vayento-media"
STORAGE_FORCE_PATH_STYLE=true
