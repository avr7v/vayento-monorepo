generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  HOST
  ADMIN
}

enum PropertyStatus {
  DRAFT
  REVIEW
  PUBLISHED
  ARCHIVED
}

enum BookingStatus {
  PENDING
  AWAITING_PAYMENT
  CONFIRMED
  CANCELLED
  COMPLETED
  EXPIRED
}

enum PaymentStatus {
  PENDING
  REQUIRES_ACTION
  SUCCEEDED
  FAILED
  REFUNDED
  CANCELLED
}

enum AvailabilityBlockType {
  AVAILABLE
  BLOCKED
  RESERVED
}

enum ReviewStatus {
  PENDING
  PUBLISHED
  HIDDEN
}

enum ConversationType {
  INQUIRY
  BOOKING
  SUPPORT
}

enum ContentStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum HostLeadStatus {
  NEW
  CONTACTED
  CONVERTED
  ARCHIVED
}

enum RefundStatus {
  PENDING
  SUCCEEDED
  FAILED
  CANCELLED
}

enum SupportTicketStatus {
  OPEN
  PENDING
  RESOLVED
  CLOSED
}

enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED
  CANCELLED
}

model User {
  id                    String                    @id @default(uuid())
  firstName             String
  lastName              String
  email                 String                    @unique
  passwordHash          String
  phone                 String?
  role                  UserRole                  @default(USER)
  isEmailVerified       Boolean                   @default(false)
  emailVerificationTokenHash String?
  emailVerificationExpiresAt DateTime?
  passwordResetTokenHash     String?
  passwordResetExpiresAt     DateTime?
  isActive              Boolean                   @default(true)
  deactivatedAt         DateTime?
  refreshTokenHash      String?
  refreshTokenExpiresAt DateTime?
  failedLoginCount      Int                       @default(0)
  lockedUntil           DateTime?
  createdAt             DateTime                  @default(now())
  updatedAt             DateTime                  @updatedAt

  profile               UserProfile?
  hostProperties        Property[]                @relation("HostProperties")
  guestBookings         Booking[]                 @relation("GuestBookings")
  hostBookings          Booking[]                 @relation("HostBookings")
  payments              Payment[]
  reviews               Review[]
  wishlistItems         Wishlist[]
  sentMessages          Message[]                 @relation("SentMessages")
  conversationLinks     ConversationParticipant[]
  authoredPages         ContentPage[]             @relation("PageAuthor")
  authoredPosts         BlogPost[]                @relation("PostAuthor")
  auditLogs             AuditLog[]                @relation("AuditActor")
  loginAttempts         LoginAttempt[]
  notificationLogs      NotificationLog[]
  hostLeads             HostLead[]                @relation("HostLeadOwner")
  supportTickets        SupportTicket[]
  favoriteSearches      FavoriteSearch[]
  hostPayouts           HostPayout[]
  disputesOpened        Dispute[]

  @@index([role])
  @@index([createdAt])
}

model UserProfile {
  id                String   @id @default(uuid())
  userId            String   @unique
  country           String?
  city              String?
  addressLine       String?
  postalCode        String?
  bio               String?
  preferredLanguage String?  @default("en")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Property {
  id                 String              @id @default(uuid())
  hostId             String
  title              String
  slug               String              @unique
  shortDescription   String
  longDescription    String
  propertyType       String
  status             PropertyStatus      @default(DRAFT)
  basePricePerNight  Decimal             @db.Decimal(10, 2)
  cleaningFee        Decimal             @default(0) @db.Decimal(10, 2)
  serviceFee         Decimal             @default(0) @db.Decimal(10, 2)
  currency           String              @default("EUR")
  maxGuests          Int
  bedrooms           Int
  bathrooms          Int
  featured           Boolean             @default(false)
  ratingAverage      Decimal             @default(0) @db.Decimal(3, 2)
  reviewsCount       Int                 @default(0)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  host               User                @relation("HostProperties", fields: [hostId], references: [id], onDelete: Cascade)
  location           PropertyLocation?
  amenities          PropertyAmenity[]
  images             PropertyImage[]
  rules              PropertyRule?
  availabilityBlocks AvailabilityBlock[]
  pricingRules       PropertyPricingRule[]
  availabilityOverrides PropertyAvailabilityOverride[]
  bookings           Booking[]
  reviews            Review[]
  wishlistItems      Wishlist[]
  conversations      Conversation[]

  @@index([hostId])
  @@index([status])
  @@index([featured])
  @@index([citySearch, status])

  citySearch         String?             // denormalized helper for search/filtering
}

model PropertyLocation {
  id          String   @id @default(uuid())
  propertyId  String   @unique
  country     String
  city        String
  region      String?
  addressLine String?
  latitude    Decimal? @db.Decimal(10, 7)
  longitude   Decimal? @db.Decimal(10, 7)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  property    Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([country])
  @@index([city])
  @@index([region])
}

model PropertyAmenity {
  id           String   @id @default(uuid())
  propertyId   String
  amenityKey   String
  amenityLabel String
  createdAt    DateTime @default(now())

  property     Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([propertyId, amenityKey])
  @@index([propertyId])
}

model PropertyImage {
  id         String   @id @default(uuid())
  propertyId String
  url        String
  storageKey String?
  altText    String?
  mimeType   String?
  sizeBytes  Int?
  width      Int?
  height     Int?
  sortOrder  Int      @default(0)
  isCover    Boolean  @default(false)
  createdAt  DateTime @default(now())

  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
  @@index([propertyId, sortOrder])
}

model PropertyRule {
  id                 String   @id @default(uuid())
  propertyId         String   @unique
  checkInTime        String?
  checkOutTime       String?
  cancellationPolicy String?
  petsAllowed        Boolean  @default(false)
  smokingAllowed     Boolean  @default(false)
  eventsAllowed      Boolean  @default(false)
  extraNotes         String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  property           Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
}

model AvailabilityBlock {
  id         String                @id @default(uuid())
  propertyId String
  startDate  DateTime
  endDate    DateTime
  blockType  AvailabilityBlockType @default(AVAILABLE)
  reason     String?
  createdAt  DateTime              @default(now())
  updatedAt  DateTime              @updatedAt

  property   Property              @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
  @@index([propertyId, startDate, endDate])
  @@index([blockType])
}


model PropertyPricingRule {
  id                String   @id @default(uuid())
  propertyId        String
  label             String
  startDate         DateTime?
  endDate           DateTime?
  weekday           Int?
  pricePerNight     Decimal? @db.Decimal(10, 2)
  priceMultiplier   Decimal? @db.Decimal(5, 2)
  minNights         Int?
  maxNights         Int?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  property          Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
  @@index([startDate, endDate])
}

model PropertyAvailabilityOverride {
  id          String   @id @default(uuid())
  propertyId  String
  date        DateTime
  isAvailable Boolean  @default(true)
  reason      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  property    Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([propertyId, date])
  @@index([propertyId])
  @@index([date])
}

model Booking {
  id               String         @id @default(uuid())
  propertyId       String
  guestUserId      String
  hostId           String
  checkInDate      DateTime
  checkOutDate     DateTime
  guestsCount      Int
  nights           Int
  bookingStatus    BookingStatus  @default(PENDING)
  subtotal         Decimal        @db.Decimal(10, 2)
  cleaningFee      Decimal        @default(0) @db.Decimal(10, 2)
  serviceFee       Decimal        @default(0) @db.Decimal(10, 2)
  taxes            Decimal        @default(0) @db.Decimal(10, 2)
  totalAmount      Decimal        @db.Decimal(10, 2)
  currency         String         @default("EUR")
  paymentStatus    PaymentStatus  @default(PENDING)
  expiresAt        DateTime?
  cancelledAt      DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  property         Property       @relation(fields: [propertyId], references: [id], onDelete: Restrict)
  guestUser        User           @relation("GuestBookings", fields: [guestUserId], references: [id], onDelete: Restrict)
  host             User           @relation("HostBookings", fields: [hostId], references: [id], onDelete: Restrict)
  guestDetails     BookingGuestDetails?
  payments         Payment[]
  reviews          Review[]
  conversations    Conversation[]
  refunds          Refund[]
  disputes         Dispute[]

  @@index([propertyId])
  @@index([guestUserId])
  @@index([hostId])
  @@index([bookingStatus])
  @@index([paymentStatus])
  @@index([checkInDate, checkOutDate])
}

model BookingGuestDetails {
  id              String   @id @default(uuid())
  bookingId       String   @unique
  firstName       String
  lastName        String
  email           String
  phone           String?
  country         String?
  city            String?
  specialRequests String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  booking         Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
}

model Payment {
  id                      String        @id @default(uuid())
  bookingId               String
  userId                  String
  provider                String        @default("stripe")
  providerPaymentIntentId String?       @unique
  amount                  Decimal       @db.Decimal(10, 2)
  currency                String        @default("EUR")
  paymentStatus           PaymentStatus @default(PENDING)
  paidAt                  DateTime?
  cardBrand               String?
  cardLast4               String?
  receiptUrl              String?
  failureReason           String?
  rawPayloadJson          Json?
  createdAt               DateTime      @default(now())
  updatedAt               DateTime      @updatedAt

  booking                 Booking       @relation(fields: [bookingId], references: [id], onDelete: Restrict)
  user                    User          @relation(fields: [userId], references: [id], onDelete: Restrict)
  refunds                 Refund[]

  @@index([bookingId])
  @@index([userId])
  @@index([paymentStatus])
  @@index([createdAt])
}

model Refund {
  id               String       @id @default(uuid())
  paymentId        String
  bookingId        String
  providerRefundId String?      @unique
  amount           Decimal      @db.Decimal(10, 2)
  currency         String       @default("EUR")
  status           RefundStatus @default(PENDING)
  reason           String?
  rawPayloadJson   Json?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  payment          Payment      @relation(fields: [paymentId], references: [id], onDelete: Restrict)
  booking          Booking      @relation(fields: [bookingId], references: [id], onDelete: Restrict)

  @@index([paymentId])
  @@index([bookingId])
  @@index([status])
}

model StripeWebhookEvent {
  id          String   @id
  type        String
  processedAt DateTime @default(now())
  payloadJson Json?

  @@index([type])
  @@index([processedAt])
}

model Review {
  id           String       @id @default(uuid())
  propertyId   String
  bookingId    String
  authorUserId String
  rating       Int
  title        String?
  comment      String
  status       ReviewStatus @default(PENDING)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  property      Property     @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  booking       Booking      @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  authorUser    User         @relation(fields: [authorUserId], references: [id], onDelete: Cascade)

  @@unique([bookingId, authorUserId])
  @@index([propertyId])
  @@index([authorUserId])
  @@index([status])
}

model Wishlist {
  id         String   @id @default(uuid())
  userId     String
  propertyId String
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([userId, propertyId])
  @@index([userId])
  @@index([propertyId])
}

model Conversation {
  id          String              @id @default(uuid())
  propertyId  String?
  bookingId   String?
  type        ConversationType    @default(INQUIRY)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  property    Property?           @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  booking     Booking?            @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  participants ConversationParticipant[]
  messages    Message[]
  supportTickets SupportTicket[]

  @@index([propertyId])
  @@index([bookingId])
  @@index([type])
}

model ConversationParticipant {
  id             String       @id @default(uuid())
  conversationId String
  userId         String
  createdAt      DateTime     @default(now())

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([conversationId])
  @@index([userId])
}

model Message {
  id             String       @id @default(uuid())
  conversationId String
  senderUserId   String
  body           String
  readAt         DateTime?
  createdAt      DateTime     @default(now())

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderUser     User         @relation("SentMessages", fields: [senderUserId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([senderUserId])
  @@index([createdAt])
}

model ContentPage {
  id              String        @id @default(uuid())
  slug            String        @unique
  title           String
  metaTitle       String?
  metaDescription String?
  content         String
  status          ContentStatus @default(DRAFT)
  authorId        String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  author          User?         @relation("PageAuthor", fields: [authorId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([authorId])
}

model BlogPost {
  id              String        @id @default(uuid())
  title           String
  slug            String        @unique
  excerpt         String?
  body            String
  coverImageUrl   String?
  status          ContentStatus @default(DRAFT)
  metaTitle       String?
  metaDescription String?
  authorId        String?
  publishedAt     DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  author          User?         @relation("PostAuthor", fields: [authorId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([authorId])
  @@index([publishedAt])
}

model HostLead {
  id           String         @id @default(uuid())
  firstName    String
  lastName     String
  email        String
  phone        String?
  propertyCity String?
  propertyCountry String?
  propertyType String?
  message      String?
  status       HostLeadStatus @default(NEW)
  assignedToId String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  assignedTo    User?          @relation("HostLeadOwner", fields: [assignedToId], references: [id], onDelete: SetNull)

  @@index([email])
  @@index([status])
  @@index([createdAt])
}

model NotificationLog {
  id                String   @id @default(uuid())
  userId            String?
  recipient         String
  type              String
  status            String
  providerMessageId String?
  error             String?
  metadataJson      Json?
  sentAt            DateTime?
  createdAt         DateTime @default(now())

  user              User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([recipient])
  @@index([type])
  @@index([status])
}

model LoginAttempt {
  id        String   @id @default(uuid())
  userId    String?
  email     String
  success   Boolean  @default(false)
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([email])
  @@index([userId])
  @@index([createdAt])
}

model FavoriteSearch {
  id          String   @id @default(uuid())
  userId      String
  name        String
  filtersJson Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model HostPayout {
  id              String        @id @default(uuid())
  hostId          String
  amount          Decimal       @db.Decimal(10, 2)
  currency        String        @default("EUR")
  status          PaymentStatus @default(PENDING)
  providerPayoutId String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  host            User          @relation(fields: [hostId], references: [id], onDelete: Restrict)

  @@index([hostId])
  @@index([status])
}

model Dispute {
  id          String        @id @default(uuid())
  bookingId   String
  openedById  String?
  status      DisputeStatus @default(OPEN)
  reason      String?
  resolution  String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  booking     Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  openedBy    User?         @relation(fields: [openedById], references: [id], onDelete: SetNull)

  @@index([bookingId])
  @@index([status])
}

model SupportTicket {
  id             String              @id @default(uuid())
  conversationId String?
  requesterId    String?
  status         SupportTicketStatus @default(OPEN)
  category       String?
  subject        String
  priority       String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  conversation   Conversation?       @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  requester      User?               @relation(fields: [requesterId], references: [id], onDelete: SetNull)

  @@index([conversationId])
  @@index([requesterId])
  @@index([status])
}

model AuditLog {
  id          String   @id @default(uuid())
  actorUserId String?
  action      String
  entityType  String
  entityId    String
  metadataJson Json?
  createdAt   DateTime @default(now())

  actor       User?    @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([actorUserId])
  @@index([entityType, entityId])
  @@index([createdAt])
}
